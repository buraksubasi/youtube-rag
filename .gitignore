# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ────────────────────────────────────────
# Frontend (Next.js)
# ────────────────────────────────────────

# dependencies
/node_modules
frontend/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
frontend/.next/
/out/

# production
/build

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# ────────────────────────────────────────
# Backend (Python / FastAPI)
# ────────────────────────────────────────

# virtual environments
venv/
.venv/
env/
backend/venv/
backend/.venv/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# mypy / ruff / pyright
.mypy_cache/
.ruff_cache/
pyrightconfig.json

# distribution / packaging
dist/
*.egg-info/

# ────────────────────────────────────────
# Docker
# ────────────────────────────────────────
qdrant_data/

# ────────────────────────────────────────
# Misc
# ────────────────────────────────────────
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
